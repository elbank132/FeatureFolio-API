{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Azure": {
    "StorageOptions": {
      "StorageUrl": "https://featurefoliostorage.blob.core.windows.net/",
      "ImagesContainerName": "images"
    },
    "ServiceBusOptions": {
      "ServiceBusNamespace": "featurefolio.servicebus.windows.net",
      "ImagesTopicName": "process-images-topic"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "Redis": {
    "KeyPrefix": "FeatureFolioAPI_",
    "Configuration": "localhost",
    "Port": 6379,
    "TTL": 30 // In minutes
  }
}
